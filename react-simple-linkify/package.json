{
  "name": "react-simple-linkify",
  "version": "2.0.4",
  "description": "Tiny, dependency-free React library that turns URLs in text into clickable links — or any custom component you want.",
  "license": "MIT",
  "author": "Yurii Khvyshchuk <owngameplay@gmail.com> (https://github.com/yurkagon)",
  "homepage": "https://github.com/yurkagon/react-simple-linkify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yurkagon/react-simple-linkify.git"
  },
  "bugs": {
    "url": "https://github.com/yurkagon/react-simple-linkify/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./MemoizedLinkify": {
      "import": {
        "types": "./dist/MemoizedLinkify.d.ts",
        "default": "./dist/MemoizedLinkify.js"
      },
      "require": {
        "types": "./dist/MemoizedLinkify.d.cts",
        "default": "./dist/MemoizedLinkify.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "cp ../README.md ./README.md && cp ../LICENSE ./LICENSE",
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify-pack": "publint && attw --pack . --profile node16"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "25.9.3",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "publint": "0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rollup": "4.62.0",
    "rollup-plugin-dts": "6.4.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "keywords": [
    "react",
    "linkify",
    "react-component",
    "link",
    "url",
    "autolink",
    "urlize",
    "urlify",
    "anchor",
    "hyperlink",
    "typescript",
    "ssr"
  ]
}
